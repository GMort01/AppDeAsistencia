# ==============================
# SmartAttendance Backend (.env)
# ==============================

# Puerto del servidor Express
PORT=3000

# Host de MySQL (localhost en tu PC, o el hostname que te dé un MySQL en la nube).
# Nota: bases PostgreSQL (p. ej. Neon) no usan estas variables con el código actual; hace falta mysql2 + dialecto MySQL.
DB_HOST=localhost

# Usuario de MySQL
DB_USER=root

# Contraseña de MySQL (NO subir el valor real al repositorio)
DB_PASSWORD=your_mysql_password

# Nombre de la base de datos
DB_NAME=smartattendance

# Puerto de MySQL
DB_PORT=3306

# Secreto usado para firmar/verificar tokens QR (usa un valor largo y único)
QR_SECRET=replace_with_a_long_random_secret